{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "opencode-server",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "packages/opencode", "--conditions=browser", "src/index.ts", "serve"],
      "port": 4096
    },
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--cwd", "packages/app", "dev"],
      "port": 3000
    },
    {
      "name": "console",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "packages/console/app", "dev"],
      "port": 5173
    },
    {
      "name": "storybook",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--cwd", "packages/storybook", "storybook"],
      "port": 6006
    },
    {
      "name": "docs",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--cwd", "packages/web", "dev"],
      "port": 4321
    }
  ]
}
